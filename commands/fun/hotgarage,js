const { SlashCommandBuilder } = require('discord.js');

module.exports = {
  data: new SlashCommandBuilder()
    .setName('hotgarage')
    .setDescription('Rate how hot your garage is.'),

  async execute(interaction) {
    const rating = Math.floor(Math.random() * 101);

    await interaction.reply(`🔥 ${interaction.user}'s garage is **${rating}% heat**.`);
  },
};